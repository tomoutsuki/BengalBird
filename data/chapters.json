  "section_details": {
    "section_1-1": {
      "description": {"en": "Learn your first vowels and consonants with audio recognition and figure matching.", "ja": "最初の母音と子音を音声認識と図のマッチングで学びます。"},
      "newLetters": "অ আ ই ক খ গ ম",
      "vocabulary": "আম, কলা, গান, মা, খাই"
    },
    "section_1-2": {
      "description": {"en": "Learn vowel signs (কার) that attach to consonants, changing their sound.", "ja": "子音に付いて音を変える母音記号（কার）を学びます。"},
      "newLetters": "া ে ি ো",
      "vocabulary": "কলা, মেলা, চিনি, রোদ"
    },
    "section_1-3": {
      "description": {"en": "Practice reading Bengali words and short phrases.", "ja": "ベンガル語の単語と短いフレーズを読む練習をします。"},
      "newLetters": "",
      "vocabulary": "Review words"
    },
    "section_1-4": {
      "description": {"en": "Learn conjunct consonants (যুক্তাক্ষর) and practice reading them.", "ja": "合字（যুক্তাক্ষর）を学び、読む練習をします。"},
      "newLetters": "্ (hasanta)",
      "vocabulary": "স্কুল, প্রথম"
    },
    "section_2-1": {
      "description": {"en": "Expand your vowel sign knowledge with new signs and positions.", "ja": "新しい母音記号とその位置を学びます。"},
      "newLetters": "ে (left), ৈ, ৌ",
      "vocabulary": "কেন, মৈত্রী, মৌসুম"
    },
    "section_2-2": {
      "description": {"en": "Learn additional vowel signs and a new consonant.", "ja": "追加の母音記号と新しい子音を学びます。"},
      "newLetters": "ু ূ দ",
      "vocabulary": "তুমি, দূর, দিন"
    },
    "section_2-3": {
      "description": {"en": "Practice vocabulary through mixed exercises.", "ja": "さまざまな練習で語彙を強化します。"},
      "newLetters": "",
      "vocabulary": "Mixed review"
    },
    "section_3-1": {
      "description": {"en": "Learn Bengali pronouns for people.", "ja": "人に関するベンガル語の代名詞を学びます。"},
